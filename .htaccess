RewriteEngine On

# Rewrite /cv/contact to contact.php
RewriteRule ^contact/?$ contact.php [L]

# Rewrite /cv/targets to list-targets.php
RewriteRule ^targets/?$ list-targets.php [L]

# Rewrite /cv/letter/target to letter.php
RewriteRule ^letter/([a-z0-9_-]+)/?$ letter.php?for=$1 [L]

# Rewrite /cv/target to index.php
RewriteRule ^([a-z0-9_-]+)/?$ index.php?for=$1 [L]
